{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/v2/odata/v4/earning-upload-srv/(.*)$",
      "target": "/v2/odata/v4/earning-upload-srv/$1",
      "authenticationType": "xsuaa",
      "destination": "earning-upload-v2-srv-api"
    },

    {
      "source": "^/odata/v4/earning-upload-srv/(.*)$",
      "target": "/odata/v4/earning-upload-srv/$1",
      "authenticationType": "xsuaa",
      "destination": "earning-upload-v2-srv-api"
    },
    {
      "source": "^/uploadearnings/(.*)$",
      "target": "/$1",
      "authenticationType": "none",
      "destination": "earning-upload-earning-upload-repo-host"
    },
    {
      "source": "^/api/(.*)$",
      "target": "/api/$1",
      "authenticationType": "xsuaa",
      "destination": "EARNINGS_CORE"
    },
    {
      "source": "^/ci_api/odata/v4/catalog/(.*)$",
      "target": "/odata/v4/catalog/$1",
      "authenticationType": "none",
      "destination": "GenAIContentIngestionSrv"
    },   
    {
      "source": "^/user-api/currentUser$",
      "target": "/currentUser",
      "service": "sap-approuter-userapi"
    },
    {
      "source": "^/resources/(.*)$",
      "target": "/resources/$1",
      "authenticationType": "none",
      "destination": "ui5"
    },
    {
      "source": "^/test-resources/(.*)$",
      "target": "/test-resources/$1",
      "authenticationType": "none",
      "destination": "ui5"
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}
