<mvc:View xmlns:unified="sap.ui.unified" controllerName="peeranalysisv2.controller.PeerAnaysisView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:uxap="sap.uxap"
    xmlns:tnt="sap.tnt">
    <Page id="page" backgroundDesign="Transparent" titleAlignment="Center" showHeader="false">
        <Select change="onAIChange" selectedKey="{chatModel>/chatMode}" class="modeSelect sapUiTinyMargin">
            <items>
                <core:Item key="peerAnalysis" text="Earnings (Peer Analysis)"/>
                <core:Item key="treasury" text="Treasury"/>
            </items>
        </Select>
        <IconTabBar id="idIconTabBarNoIcons" class="tabcontainer" expanded="true" expandable="false" headerBackgroundDesign="Transparent" backgroundDesign="Transparent">
            <items>
                <IconTabFilter visible="{= ${chatModel>/chatMode} === 'peerAnalysis' }" text="Analyze earnings results" key="chatbox">
                    <VBox class="styleBox1">
                        <Panel class="sapMShellGlobalOuterBackground sapUiContentPadding">
                            <core:Fragment fragmentName="peeranalysisv2.fragment.chatBox" type="XML"/>
                        </Panel>
                    </VBox>
                    <VBox class="resultBoxContainer">
                        <FlexBox class="ResultFlexBox" visible="{chatModel>/visibleResult}">
                            <core:Fragment fragmentName="peeranalysisv2.fragment.resultBox" type="XML"/>
                        </FlexBox>
                    </VBox>
                </IconTabFilter>
                <IconTabFilter visible="{= ${chatModel>/chatMode} === 'treasury' }" text="Treasury" key="treasury">
                    <VBox class="styleBox1">
                        <Panel class="sapMShellGlobalOuterBackground sapUiContentPadding">
                            <core:Fragment fragmentName="peeranalysisv2.fragment.treasuryChatBox" type="XML"/>
                        </Panel>
                    </VBox>
                    <VBox class="resultBoxContainer">
                        <FlexBox class="ResultFlexBox" visible="{chatModel>/visibleTreasuryResult}">
                            <core:Fragment fragmentName="peeranalysisv2.fragment.treasuryResultBox" type="XML"/>
                        </FlexBox>
                    </VBox>
                </IconTabFilter>
                <IconTabFilter visible="{= ${chatModel>/chatMode} === 'peerAnalysis' }" text="Generate report" key="report">
                    <VBox class="styleBox1">
                        <Panel class="sapMShellGlobalOuterBackground sapUiContentPadding">
                            <VBox>
                                <Text text="Generate standard report" class="generateReportTitle sapUiSmallMarginBottom"></Text>
                                <HBox>
                                    <Text class="intro-text" text="Step 1: If you don't have it, "></Text>
                                    <Link class="intro-text sapUiTinyMarginBegin" text="download prompt template" href="{chatModel>/downloadTemplateLink}" target="_blank"></Link>
                                </HBox>
                                <Text class="intro-text" text="Step 2: Edit fields in prompt template in Excel"></Text>
                                <Text class="intro-text" text="Step 3: Upload prompt template and generate report"></Text>
                                <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginTop">
                                    <HBox>
                                        <unified:FileUploader id="promptFileUploader" placeholder="Choose a prompt template file..." class="sapUiTinyMarginEnd" buttonText="Browse" change="onPromptFileUpload" uploadComplete="onPromptFileUploadComplete" icon="sap-icon://attachment" tooltip="Upload File"/>
                                    </HBox>
                                    <Button text="Generate Report" type="Emphasized" press="onGenerateReport" class="sapUiTinyMarginLeft" enabled="{chatModel>/enableSubmit}"/>
                                </HBox>
                                <FlexBox alignItems="Center" class="sapUiSmallMarginTop">
                                    <core:Icon src="sap-icon://hint" class="sapUiTinyMarginEnd" color="#0072B9" />
                                    <Text class="sapUiTinyMarginEnd" text="You can verify the currently used"></Text>
                                    <Link text="standard account line mapping" press=".onDownloadMetadata"></Link>
                                </FlexBox>
                            </VBox>
                        </Panel>
                        <Table class="sapUiSmallMarginTop" items="{chatModel>/fileStatus}" visible="{chatModel>/fileStatusVisible}">
                            <columns>
                                <Column>
                                    <Text text="Uploaded Files"/>
                                </Column>
                                <Column>
                                    <Text text="Status"/>
                                </Column>
                                <Column>
                                    <Text text="Download"/>
                                </Column>
                                <Column>
                                    <Text text="View"/>
                                </Column>
                                <Column>
                                    <Text text="Date generated"/>
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Link text="{chatModel>filename}"/>
                                        <HBox>
                                            <core:Icon class="sapUiTinyMarginEnd" src="{path:'chatModel>status', formatter:'.formatProcessingStatusIcon'}" color="#0473EA"/>
                                            <Text text="{chatModel>status}"/>
                                        </HBox>
                                        <Button enabled="{= ${chatModel>status} === 'completed'}" type="Transparent" icon="sap-icon://download" press=".onDownloadReport" text="Download"></Button>
                                        <Button enabled="{= ${chatModel>status} === 'completed'}" type="Transparent" icon="sap-icon://show" press=".onViewReport" text="View"></Button>
                                        <Text text="{path:'chatModel>created_at', formatter:'.formatDateTime'}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                    <VBox class="resultBoxContainer">
                        <FlexBox class="ResultFlexBox" visible="{chatModel>/generateVisibleResult}">
                            <core:Fragment fragmentName="peeranalysisv2.fragment.promptResultBox" type="XML"/>
                        </FlexBox>
                    </VBox>
                </IconTabFilter>
            </items>
        </IconTabBar>
        
</Page>
</mvc:View>