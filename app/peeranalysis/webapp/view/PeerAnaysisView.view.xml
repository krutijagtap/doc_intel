<mvc:View xmlns:unified="sap.ui.unified" controllerName="peeranalysisv2.controller.PeerAnaysisView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:uxap="sap.uxap"
    xmlns:tnt="sap.tnt">
    <Page id="page" backgroundDesign="Transparent" titleAlignment="Center" showHeader="false">
        <IconTabBar id="idIconTabBarNoIcons" class="tabcontainer" expanded="true" expandable="false" headerBackgroundDesign="Transparent" backgroundDesign="Transparent">
            <items>
                <IconTabFilter text="Analyze earnings results" key="chatbox">
                    <VBox class="styleBox1">
                        <Panel class="sapMShellGlobalOuterBackground sapUiContentPadding">
                            <core:Fragment fragmentName="peeranalysisv2.fragment.chatBox" type="XML"/>
                        </Panel>
                    </VBox>
                    <VBox class="resultBoxContainer">
                        <FlexBox id="resultFlexBox" class="ResultFlexBox" visible="{chatModel>/visibleResult}">
                            <core:Fragment fragmentName="peeranalysisv2.fragment.resultBox" type="XML"/>
                        </FlexBox>
                    </VBox>
                </IconTabFilter>
                <IconTabFilter text="Generate report" key="report">
                    <VBox class="styleBox1">
                        <Panel class="sapMShellGlobalOuterBackground sapUiContentPadding">
                            <VBox>
                                <Text text="Generate standard report" class="generateReportTitle sapUiSmallMarginBottom"></Text>
                                <HBox>
                                    <Text text="Step 1: If you don't have it, "></Text>
                                    <Link text="download prompt template" href="https://example.com/download" class="sapUiTinyMarginBegin" target="_blank"></Link>
                                </HBox>
                                <Text text="Step 2: Edit fields in prompt template in Excel"></Text>
                                <Text text="Step 3: Upload prompt template and generate report"></Text>
                                <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginTop">
                                    <HBox>
                                        <unified:FileUploader id="promptFileUploader" class="sapUiTinyMarginEnd" buttonOnly="true" iconFirst="false" buttonText="Add prompt template" change="onPromptFileUpload" uploadComplete="onPromptFileUploadComplete" icon="sap-icon://attachment" tooltip="Upload File"/>
                                    </HBox>
                                    <Button text="Generate Report" type="Emphasized" press="onGenerateReport" class="sapUiTinyMarginLeft" enabled="{chatModel>/enableSubmit}"/>
                                </HBox>
                                <FlexBox alignItems="Center" class="sapUiSmallMarginTop">
                                    <core:Icon src="sap-icon://hint" class="sapUiTinyMarginEnd" color="#0072B9" />
                                    <Text text="You can verify the currently used" class="sapUiTinyMarginEnd"></Text>
                                    <Link text="standard account line mapping" press=".onDownload"></Link>
                                </FlexBox>
                            </VBox>
                        </Panel>
                        <Table class="sapUiSmallMarginTop" items="{chatModel>/resultItems}">
                            <columns>
                                <Column>
                                    <Text text="Uploaded Files"/>
                                </Column>
                                <Column>
                                    <Text text="Status"/>
                                </Column>
                                <Column>
                                    <Text text="Download"/>
                                </Column>
                                <Column>
                                    <Text text="View"/>
                                </Column>
                                <Column>
                                    <Text text="Date generated"/>
                                </Column>
                            </columns>
                            <items>
                                <ColumnListItem>
                                    <cells>
                                        <Link text="{chatModel>fileName}"/>
                                        <HBox>
                                            <core:Icon src="{path:'chatModel>status', formatter:'.formatProcessingStatusIcon'}"/>
                                            <Text text="{chatModel>status}"/>
                                        </HBox>
                                        <Button type="Transparent" icon="sap-icon://download" press=".onDownload" text="Download"></Button>
                                        <Button type="Transparent" icon="sap-icon://show" press=".onViewReport" text="View"></Button>
                                        <Text text="{chatModel>dateGenerated}"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>
                    <VBox class="resultBoxContainer">
                        <FlexBox class="ResultFlexBox" visible="{chatModel>/generateVisibleResult}">
                            <!-- <core:Fragment fragmentName="peeranalysisv2.fragment.resultBox" type="XML"/> -->
                        </FlexBox>
                    </VBox>
                </IconTabFilter>
            </items>
        </IconTabBar>
        
</Page>
</mvc:View>