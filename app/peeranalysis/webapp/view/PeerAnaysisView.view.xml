<mvc:View xmlns:unified="sap.ui.unified" controllerName="peeranalysis.controller.PeerAnaysisView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:uxap="sap.uxap"
    xmlns:tnt="sap.tnt">
    <Page id="page" title="Peer Analysis - AskFinSight" backgroundDesign="List" titleAlignment="Center">
        <IconTabBar id="idIconTabBarNoIcons" expanded="true" expandable="false" class="sapUiContentPadding" backgroundDesign="Transparent">
            <items>
                <IconTabFilter text="Ask Anything" key="chatbox">
                    <VBox class="styleBox1">
                        <Panel class="sapMShellGlobalOuterBackground sapUiContentPadding">
                            <core:Fragment fragmentName="peeranalysis.fragment.chatBox" type="XML"/>
                        </Panel>
                    </VBox>
                </IconTabFilter>
                <IconTabFilter text="Generate report" key="report">
                    <VBox class="styleBox1">
                        <Panel class="sapMShellGlobalOuterBackground sapUiContentPadding">
                            <VBox>
                                <Text text="Generate standard report" class="generateReportTitle sapUiSmallMarginBottom"></Text>
                                <HBox>
                                    <Text text="Step 1: If you don't have it, "></Text>
                                    <Link text="download prompt template" href="https://example.com/download" class="sapUiTinyMarginBegin" target="_blank"></Link>
                                </HBox>
                                <Text text="Step 2: Edit fields in prompt template in Excel"></Text>
                                <Text text="Step 3: Upload prompt template and generate report"></Text>
                                <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginTop">
                                    <HBox>
                                        <unified:FileUploader id="promptFileUploader" class="sapUiTinyMarginEnd" buttonOnly="true" iconFirst="false" buttonText="Add prompt template" change="onPromptFileUpload" uploadComplete="onPromptFileUploadComplete" icon="sap-icon://attachment" tooltip="Upload File"/>
                                        <unified:FileUploader id="mapperFileUploader" buttonOnly="true" iconFirst="false" buttonText="Add mapper" change="onMapperFileUpload" uploadComplete="onMapperFileUploadComplete" icon="sap-icon://attachment" tooltip="Upload File" />
                                    </HBox>
                                    <Button text="Generate Report" type="Emphasized" press="onGenerateReport" class="sapUiTinyMarginLeft" enabled="{chatModel>/enableSubmit}"/>
                                </HBox>
                                <HBox class="sapUiSmallMarginTop" alignContent="Center">
                                    <core:Icon class="brandColor sapUiTinyMarginEnd" src="sap-icon://hint" />
                                    <Text class="fontBold sapUiTinyMarginEnd" text="Mapper is optional:"></Text>
                                    <Text text="Only required for new banks or existing banks that have changed their nomenclature."></Text>
                                </HBox>
                            </VBox>
                        </Panel>
                    </VBox>
                </IconTabFilter>
            </items>
        </IconTabBar>
        <VBox class="resultBoxContainer">

            <FlexBox id="resultFlexBox" class="ResultFlexBox" visible="{chatModel>/visibleResult}">
                <core:Fragment fragmentName="peeranalysis.fragment.resultBox" type="XML"/>
            </FlexBox>


        </VBox>
</Page>
</mvc:View>