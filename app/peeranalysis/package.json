{
  "name": "peeranalysis",
  "version": "0.0.1",
  "description": "An SAP Fiori application.",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "devDependencies": {
    "@sap/ux-ui5-tooling": "1",
    "@ui5/cli": "^3.0.0",
    "ui5-task-zipper": "^3.4.x",
    "ui5-tooling-stringreplace": "^3.4.1"
  },
  "scripts": {
    "start": "UI5_ENV=dev ui5 serve --config ui5.yaml --port 8088",
    "deploy-config": "npx -p @sap/ux-ui5-tooling fiori add deploy-config cf",
    "build": "UI5_ENV=prod ui5 build --clean-dest --config ui5-deploy.yaml --include-task=generateCachebusterInfo",
    "build:cf": "UI5_ENV=prod ui5 build preload --clean-dest --config ui5-deploy.yaml --include-task=generateCachebusterInfo"
  }
}
